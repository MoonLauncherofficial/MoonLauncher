{
  "name": "moonlauncher",
  "version": "1.1.7",
  "description": "MoonLauncher - Твой портал в мир игры",
  "main": "src/main/main.js",
  "author": "MoonLauncher Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MoonLauncherofficial/MoonLauncher.git"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "adm-zip": "^0.5.16",
    "@minescope/mineping": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ru.moonlauncher.app",
    "productName": "MoonLauncher",
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "MoonLauncherofficial",
      "repo": "MoonLauncher"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Game"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    }
  }
}
